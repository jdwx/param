{
  "name": "jdwx/param",
  "description": "A simple PHP module for parsing values from strings with type safety.",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "JDWX\\Param\\": "src/"
    }
  },
  "require": {
    "php": ">=8.3",
    "ext-mbstring": "*",
    "php-ds/php-ds": "^v1.5.0",
    "jdwx/strict": "^1.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "jetbrains/phpstorm-attributes": "^1.0",
    "phpunit/phpunit": "^12",
    "phan/phan": "^v6",
    "phpstan/phpstan": "^2.0"
  },
  "scripts": {
    "phan": "PHAN_ALLOW_XDEBUG=1 php -d xdebug.mode=off vendor/bin/phan --no-progress-bar --analyze-twice",
    "phpstan": "php -d xdebug.so -d memory_limit=-1 vendor/bin/phpstan --no-progress",
    "phpunit": "vendor/bin/phpunit tests"
  }
}

